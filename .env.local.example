# ─────────────────────────────────────────────────────────────
# Lumino Agency — Environment Variables
# Copy this file to `.env.local` and fill in real values.
# Never commit `.env.local` (it is gitignored).
# ─────────────────────────────────────────────────────────────

# ── Supabase ────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_DB_PASSWORD=

# ── Google Maps ─────────────────────────────────────────────
GOOGLE_MAPS_API_KEY=

# ── Claude (Anthropic) ──────────────────────────────────────
CLAUDE_API_KEY=

# ── Unsplash (foto fallback) ────────────────────────────────
UNSPLASH_ACCESS_KEY=

# ── Pexels Videos (hero video) ──────────────────────────────
# Signup gratis su https://www.pexels.com/api/
PEXELS_API_KEY=

# ── Porkbun (domini Pro/Premium — non ancora attivato) ──────
# PORKBUN_API_KEY=
# PORKBUN_SECRET_KEY=

# ── Vercel (deployments) ────────────────────────────────────
VERCEL_TOKEN=

# ── Cron (protects /api/cron/* and /api/pipeline/generate) ──
# Vercel Cron sends this as `Authorization: Bearer <CRON_SECRET>`.
CRON_SECRET=

# ── Outreach Apps Script (gmail batch sender) ───────────────
# Bearer token usato da Apps Script per chiamare /api/outreach/*
OUTREACH_SECRET=

# ── Whapi.Cloud (WhatsApp bot Ezio) ─────────────────────────
WHAPI_TOKEN=
WHAPI_BASE_URL=https://api.whapi.cloud
WHAPI_CHANNEL_ID=
# Token per validare i webhook in entrata
WHATSAPP_WEBHOOK_SECRET=

# ── Google Sheets event tracker (Apps Script web app) ───────
# URL del deployment Apps Script (.../exec) + secret nel payload
LUMINO_SHEET_WEBHOOK_URL=
LUMINO_SHEET_SECRET=

# ── Reservations email flow (stesso Apps Script, kind diverso) ──
# Tutti e 3 puntano allo stesso URL Apps Script (gestisce vari kind)
LUMINO_RESERVATION_ACK_URL=
LUMINO_OWNER_NOTIFY_URL=
LUMINO_RESERVATION_OUTCOME_URL=

# ── Zoho SMTP outreach (4 sender + 1 prenotazioni) ──────────
# Vedi scripts/dns-setup-instructions.md per il setup DNS/MX su Namecheap.
# Le password sono cifrate AES-256-GCM con OUTREACH_SMTP_KEY.
OUTREACH_SMTP_KEY=
ZOHO_SMTP_LUCA_PASSWORD=
ZOHO_SMTP_PIETRO_PASSWORD=
ZOHO_SMTP_GIOVANNI_PASSWORD=
ZOHO_SMTP_GABRIELE_PASSWORD=

# Sender prenotazioni dedicato (mittente neutro per ack/conferma/annullo)
ZOHO_SMTP_PRENOTAZIONI_USER=prenotazioni@bylumino.com
ZOHO_SMTP_PRENOTAZIONI_PASSWORD=
