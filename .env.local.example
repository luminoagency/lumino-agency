# ─────────────────────────────────────────────────────────────
# Lumino Agency — Environment Variables
# Copy this file to `.env.local` and fill in real values.
# Never commit `.env.local` (it is gitignored).
# ─────────────────────────────────────────────────────────────

# ── Supabase ────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_DB_PASSWORD=

# ── Google Maps ─────────────────────────────────────────────
GOOGLE_MAPS_API_KEY=

# ── Claude (Anthropic) ──────────────────────────────────────
CLAUDE_API_KEY=

# ── Unsplash (foto fallback) ────────────────────────────────
UNSPLASH_ACCESS_KEY=

# ── Pexels Videos (hero video) ──────────────────────────────
# Signup gratis su https://www.pexels.com/api/
PEXELS_API_KEY=

# ── Porkbun (domini Pro/Premium — non ancora attivato) ──────
# PORKBUN_API_KEY=
# PORKBUN_SECRET_KEY=

# ── Vercel (deployments) ────────────────────────────────────
VERCEL_TOKEN=

# ── Cron (protects /api/cron/* and /api/pipeline/generate) ──
# Vercel Cron sends this as `Authorization: Bearer <CRON_SECRET>`.
CRON_SECRET=

# ── Outreach Apps Script (gmail batch sender) ───────────────
# Bearer token usato da Apps Script per chiamare /api/outreach/*
OUTREACH_SECRET=

# ── Whapi.Cloud (WhatsApp bot Ezio) ─────────────────────────
WHAPI_TOKEN=
WHAPI_BASE_URL=https://api.whapi.cloud
WHAPI_CHANNEL_ID=
# Token per validare i webhook in entrata
WHATSAPP_WEBHOOK_SECRET=

# ── Google Sheets event tracker (Apps Script web app) ───────
# URL del deployment Apps Script (.../exec) + secret nel payload
LUMINO_SHEET_WEBHOOK_URL=
LUMINO_SHEET_SECRET=
