# ─────────────────────────────────────────────────────────────
# Lumino Agency — Environment Variables
# Copy this file to `.env.local` and fill in real values.
# Never commit `.env.local` (it is gitignored).
# ─────────────────────────────────────────────────────────────

# ── Supabase ────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_DB_PASSWORD=

# ── Google Maps ─────────────────────────────────────────────
GOOGLE_MAPS_API_KEY=

# ── Claude (Anthropic) ──────────────────────────────────────
CLAUDE_API_KEY=

# ── Unsplash ────────────────────────────────────────────────
UNSPLASH_ACCESS_KEY=

# ── Ideogram ────────────────────────────────────────────────
IDEOGRAM_API_KEY=

# ── Porkbun (domains) ───────────────────────────────────────
PORKBUN_API_KEY=
PORKBUN_SECRET_KEY=

# ── Vercel (deployments) ────────────────────────────────────
VERCEL_TOKEN=

# ── Cron (protects /api/cron/* routes) ──────────────────────
# Vercel Cron sends this as `Authorization: Bearer <CRON_SECRET>`.
# Set the same value in the Vercel project env and in .env.local.
CRON_SECRET=
